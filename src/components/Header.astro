---
import { site } from '../data/site';
import { getLang, t, localizePath, navItems, locales } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
const currentPath = Astro.url.pathname;
const base = currentPath.replace(/^\/(de)(?=\/|$)/, '') || '/';
const isActive = (href: string) => (href === '/' ? base === '/' : base.startsWith(href));

const homeHref = localizePath('/', lang);
const contactHref = localizePath('/contact', lang);
---

<header class="hdr" id="site-header">
  <div class="container hdr__inner">
    <button class="hdr__burger" aria-label="Menu" aria-expanded="false" id="burger">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" aria-label="Primary">
      {navItems.map((item) => (
        <a href={localizePath(item.href, lang)} class:list={['nav__link', { 'is-active': isActive(item.href) }]}>
          {tr.nav[item.key]}
        </a>
      ))}
    </nav>

    <div class="hdr__tools">
      <details class="lang-dd" id="lang-dd">
        <summary class="lang-dd__btn" aria-label="Language" title="Language">
          <span>{languages[lang].short}</span>
          <svg class="lang-dd__chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6l4 4 4-4" /></svg>
        </summary>
        <ul class="lang-dd__menu" role="menu">
          {locales.map((loc) => (
            <li role="none">
              <a
                role="menuitem"
                href={localizePath(currentPath, loc)}
                hreflang={loc}
                class:list={['lang-dd__opt', { 'is-active': loc === lang }]}
                aria-current={loc === lang ? 'true' : undefined}
              >
                <span class="lang-dd__code">{languages[loc].short}</span>
                <span class="lang-dd__label">{languages[loc].label}</span>
              </a>
            </li>
          ))}
        </ul>
      </details>

      <a href={contactHref} class="btn hdr__cta">{tr.common.getInTouch}</a>
    </div>

    <a href={homeHref} class="brand" aria-label={site.name}>
      <span class="brand__text">
        <span class="brand__top">BETOPLAST</span>
        <span class="brand__bottom">Energy &amp; Infrastructure</span>
      </span>
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.3 2 5 13.4h4.9L8.7 22l8.3-12.1h-5z" /></svg>
      </span>
    </a>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    {navItems.map((item) => (
      <a href={localizePath(item.href, lang)} class:list={['mobile-nav__link', { 'is-active': isActive(item.href) }]}>
        {tr.nav[item.key]}
      </a>
    ))}
    <div class="mobile-langs">
      {locales.map((loc) => (
        <a href={localizePath(currentPath, loc)} class:list={['mlang', { 'is-active': loc === lang }]} hreflang={loc}>
          {languages[loc].short}
        </a>
      ))}
    </div>
    <a href={contactHref} class="btn btn--primary" style="margin: 1rem 1.5rem;">{tr.common.getInTouch}</a>
  </div>
</header>

<style>
  /* Fixed, transparent over the dark hero — turns solid graphite on scroll. */
  .hdr {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    color: #fff;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background .3s var(--ease), border-color .3s var(--ease), box-shadow .3s var(--ease);
  }
  .hdr.scrolled {
    background: rgba(15, 19, 24, .9);
    backdrop-filter: saturate(160%) blur(14px);
    border-bottom-color: rgba(255, 255, 255, .08);
    box-shadow: 0 8px 30px rgba(0, 0, 0, .28);
  }
  .hdr__inner { display: flex; align-items: center; gap: 1.1rem; height: 76px; }

  /* ----- left: nav ----- */
  .nav { display: flex; gap: .35rem; margin-right: auto; }
  .nav__link {
    position: relative;
    padding: .5rem .2rem;
    font-size: .82rem; font-weight: 600; letter-spacing: .04em; text-transform: uppercase;
    color: rgba(255, 255, 255, .7);
    transition: color .18s var(--ease);
    white-space: nowrap;
  }
  .nav__link + .nav__link { margin-left: 1.15rem; }
  .nav__link::after {
    content: ""; position: absolute; left: 0; right: 100%; bottom: -2px; height: 2px;
    background: var(--spark); transition: right .25s var(--ease);
  }
  .nav__link:hover { color: #fff; }
  .nav__link:hover::after { right: 0; }
  .nav__link.is-active { color: #fff; }
  .nav__link.is-active::after { right: 0; }

  /* ----- middle-right: tools ----- */
  .hdr__tools { display: flex; align-items: center; gap: .7rem; }

  .lang-dd { position: relative; flex: none; }
  .lang-dd__btn {
    list-style: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: .35rem;
    padding: .4rem .55rem; border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, .25); background: transparent;
    font-size: .8rem; font-weight: 600; letter-spacing: .03em; color: #fff;
    transition: border-color .18s var(--ease), background .18s var(--ease);
  }
  .lang-dd__btn::-webkit-details-marker { display: none; }
  .lang-dd__btn:hover { border-color: rgba(255, 255, 255, .55); background: rgba(255, 255, 255, .08); }
  .lang-dd__chev { width: 12px; height: 12px; opacity: .7; transition: transform .2s var(--ease); }
  .lang-dd[open] .lang-dd__chev { transform: rotate(180deg); }
  .lang-dd[open] .lang-dd__btn { border-color: rgba(255, 255, 255, .55); background: rgba(255, 255, 255, .08); }
  .lang-dd__menu {
    position: absolute; left: 0; top: calc(100% + 8px); z-index: 60;
    min-width: 158px; margin: 0; padding: .35rem; list-style: none;
    background: #161c24; border: 1px solid rgba(255, 255, 255, .1); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .lang-dd__opt {
    display: flex; align-items: center; gap: .65rem;
    padding: .5rem .6rem; border-radius: var(--radius);
    font-size: .92rem; color: rgba(255, 255, 255, .85); transition: background .15s var(--ease);
  }
  .lang-dd__opt:hover { background: rgba(255, 255, 255, .07); }
  .lang-dd__opt.is-active { color: var(--spark-300); font-weight: 600; }
  .lang-dd__code { font-size: .72rem; font-weight: 700; letter-spacing: .04em; color: rgba(255, 255, 255, .5); width: 2ch; }
  .lang-dd__opt.is-active .lang-dd__code { color: var(--spark-300); }

  .hdr__cta {
    padding: .55rem 1.05rem; font-size: .82rem; white-space: nowrap; flex: none;
    text-transform: uppercase; letter-spacing: .04em;
    color: var(--ink); background: #fff;
  }
  .hdr__cta:hover { background: var(--spark-300); transform: translateY(-1px); }

  /* ----- far right: logo ----- */
  .brand { display: flex; align-items: center; gap: .65rem; flex: none; padding-left: .4rem; }
  .brand__text { display: flex; flex-direction: column; line-height: 1; white-space: nowrap; text-align: right; }
  .brand__top {
    font-family: var(--font-display); font-weight: 700; font-size: 1.12rem;
    letter-spacing: .03em; color: #fff;
  }
  .brand__bottom {
    font-family: var(--font-display); font-weight: 600; text-transform: uppercase;
    font-size: .58rem; letter-spacing: .14em; color: var(--spark-300);
    margin-top: .3rem;
  }
  .brand__mark {
    width: 44px; height: 44px; border-radius: 10px; flex: none;
    display: grid; place-items: center;
    background: var(--blue); color: #fff;
    box-shadow: 0 6px 18px rgba(23, 99, 214, .45);
  }
  .brand__mark svg { width: 22px; height: 22px; }

  /* ----- burger ----- */
  .hdr__burger { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 8px; margin-right: auto; }
  .hdr__burger span { width: 24px; height: 2px; background: #fff; transition: transform .25s var(--ease), opacity .2s; }
  .hdr__burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hdr__burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .hdr__burger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav { background: #11151b; border-top: 1px solid rgba(255,255,255,.08); padding-block: .5rem; }
  .mobile-nav__link { display: block; padding: .9rem 1.5rem; font-weight: 600; letter-spacing: .03em; text-transform: uppercase; font-size: .85rem; color: rgba(255,255,255,.8); border-bottom: 1px solid rgba(255,255,255,.06); }
  .mobile-nav__link.is-active { color: #fff; }
  .mobile-langs { display: flex; gap: .4rem; padding: 1rem 1.5rem .25rem; }
  .mlang {
    font-size: .8rem; font-weight: 600; letter-spacing: .03em; color: rgba(255,255,255,.6);
    padding: .4rem .7rem; border-radius: var(--radius); border: 1px solid rgba(255,255,255,.18);
  }
  .mlang.is-active { color: var(--spark-300); border-color: var(--spark-300); }

  @media (max-width: 1100px) {
    .nav, .hdr__tools { display: none; }
    .hdr__burger { display: flex; }
    .brand__bottom { display: none; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-nav');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });

  // Language dropdown: close on outside click or Escape.
  const dd = document.getElementById('lang-dd') as HTMLDetailsElement | null;
  if (dd) {
    document.addEventListener('click', (e) => {
      if (dd.open && !dd.contains(e.target as Node)) dd.open = false;
    });
    dd.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') dd.open = false;
    });
  }
</script>
