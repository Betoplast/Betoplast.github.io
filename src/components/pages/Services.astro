---
import Base from '../../layouts/Base.astro';
import CtaBand from '../CtaBand.astro';
import { getLang, t } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
const s = tr.services;
---

<Base title={tr.nav.services} description={s.heroLead}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">{s.heroEyebrow}</p>
      <h1>{s.heroH1}</h1>
      <p class="lead mt-2">{s.heroLead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container svc-list">
      {s.items.map((item, i) => (
        <article class="svc reveal">
          <div class="svc__head">
            <span class="svc__no">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h2>{item.title}</h2>
              <p class="lead mt-1">{item.summary}</p>
            </div>
          </div>
          <ul class="svc__points">
            {item.points.map((p) => <li>{p}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <CtaBand heading={s.ctaHeading} text={s.ctaText} />
</Base>

<style>
  .page-hero { background: var(--ink); color: #fff; padding-block: clamp(3.5rem, 8vw, 6rem); }
  .page-hero h1 { color: #fff; }
  .page-hero .lead { color: #aab6c4; max-width: 60ch; }
  .page-hero .eyebrow { color: var(--blue-300); }
  .page-hero .eyebrow::before { background: var(--spark-300); }

  .svc-list { display: flex; flex-direction: column; gap: 0; }
  .svc {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-block: clamp(2.2rem, 4vw, 3.2rem); border-top: 1px solid var(--line); align-items: start;
  }
  .svc:last-child { border-bottom: 1px solid var(--line); }
  .svc__head { display: flex; gap: 1.2rem; align-items: baseline; }
  .svc__no {
    font-family: var(--font-display); font-weight: 700; font-size: 1.1rem;
    color: var(--blue-500); letter-spacing: .04em; flex: none;
  }
  .svc__head h2 { font-size: clamp(1.5rem, 2.6vw, 2rem); }
  .svc__points { display: flex; flex-direction: column; gap: .7rem; padding-top: .3rem; }
  .svc__points li { position: relative; padding-left: 1.4rem; color: var(--ink); font-size: .98rem; }
  .svc__points li::before {
    content: ""; position: absolute; left: 0; top: .55em;
    width: 7px; height: 7px; background: var(--spark); border-radius: 1px;
  }
  @media (max-width: 820px) { .svc { grid-template-columns: 1fr; gap: 1.2rem; } }
</style>
