---
import Base from '../../layouts/Base.astro';
import CtaBand from '../CtaBand.astro';
import { site } from '../../data/site';
import { getLang, t } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
---

<Base title={tr.nav.about} description={tr.about.heroLead}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">{tr.about.heroEyebrow}</p>
      <h1>{tr.about.heroH1}</h1>
      <p class="lead mt-2">{tr.about.heroLead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div class="reveal">
        <p class="eyebrow">{tr.about.whoEyebrow}</p>
        <h2>{tr.about.whoH2}</h2>
      </div>
      <div class="reveal">
        <p>{tr.about.whoP1}</p>
        <p class="mt-3">{tr.about.whoP2}</p>
        <dl class="facts mt-4">
          <div><dt>{tr.about.factLegal}</dt><dd>{tr.legalEntity}</dd></div>
          <div><dt>{tr.about.factUid}</dt><dd>{site.uid}</dd></div>
          <div><dt>{tr.about.factFounded}</dt><dd>{site.founded}</dd></div>
          <div><dt>{tr.about.factLocation}</dt><dd>{tr.address.line2}, {tr.address.country}</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">{tr.about.approachEyebrow}</p>
        <h2>{tr.about.approachH2}</h2>
        <p class="lead mt-2">{tr.about.approachLead}</p>
      </div>
      <div class="grid cols-2">
        {tr.about.tracks.map((s) => (
          <div class="track-card card reveal">
            <span class="track-card__tag">{s.tag}</span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <a class="related card reveal" href={site.related.url} target="_blank" rel="noopener">
        <div class="related__body">
          <p class="eyebrow">{tr.related.eyebrow}</p>
          <p class="related__text">{tr.related.text}</p>
        </div>
        <span class="related__cta">{tr.related.cta} <span class="arrow">↗</span></span>
      </a>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .page-hero { background: var(--ink); color: #fff; padding-top: calc(76px + clamp(2.5rem, 6vw, 4.5rem)); padding-bottom: clamp(3.5rem, 8vw, 6rem); }
  .page-hero h1 { color: #fff; }
  .page-hero .lead { color: #aab6c4; max-width: 62ch; }
  .page-hero .eyebrow { color: var(--blue-300); }
  .page-hero .eyebrow::before { background: var(--spark-300); }

  .two-col { display: grid; grid-template-columns: 1fr 1.5fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  @media (max-width: 820px) { .two-col { grid-template-columns: 1fr; gap: 1.5rem; } }

  .track-card { padding: 2rem; }
  .track-card__tag {
    display: inline-block; font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    color: var(--blue); background: var(--bg-soft-2); padding: .35rem .7rem; border-radius: 3px; margin-bottom: 1rem;
  }
  .track-card h3 { margin-bottom: .7rem; }
  .track-card p { color: var(--muted); font-size: .96rem; }

  .facts { display: flex; flex-direction: column; gap: .9rem; }
  .facts > div { display: flex; gap: 1rem; padding-bottom: .9rem; border-bottom: 1px solid var(--line); }
  .facts dt { width: 130px; flex: none; font-size: .85rem; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; padding-top: .1rem; }
  .facts dd { font-weight: 500; }

  .related {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
    padding: clamp(1.6rem, 3vw, 2.4rem);
    background: var(--bg-soft); border-color: var(--line);
  }
  .related__body { max-width: 64ch; }
  .related__text { margin-top: .6rem; color: var(--ink); }
  .related__cta { font-weight: 600; color: var(--blue); white-space: nowrap; display: inline-flex; align-items: center; gap: .4rem; }
  .related:hover .related__cta .arrow { transform: translate(2px, -2px); }
  .related__cta .arrow { transition: transform .2s var(--ease); }
</style>
