---
import Base from '../../layouts/Base.astro';
import CtaBand from '../CtaBand.astro';
import { getLang, t, localizePath } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);

const statIcons = [
  '<path d="M3 21h18" /><path d="M5 21V8l7-5 7 5v13" /><path d="M9 21v-6h6v6" />',
  '<path d="M12 2v6" /><path d="M5 8h14l-1.5 12a2 2 0 0 1-2 1.8H8.5a2 2 0 0 1-2-1.8z" /><path d="M9 13h6" />',
  '<rect x="3" y="9" width="8" height="12" rx="1" /><rect x="13" y="4" width="8" height="17" rx="1" /><path d="M6 13h2M6 17h2M16 8h2M16 12h2M16 16h2" />',
  '<path d="M3 17l5-5 4 4 8-8" /><path d="M21 8v5h-5" /><path d="M3 21h18" />',
];
---

<Base>
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="eyebrow">{tr.home.heroEyebrow}</p>
      <h1 set:html={tr.home.heroH1} />
      <p class="lead">{tr.home.heroLead}</p>
      <div class="hero__actions">
        <a href={localizePath('/services', lang)} class="btn btn--light">{tr.common.exploreServices} <span class="arrow">→</span></a>
        <a href={localizePath('/contact', lang)} class="btn btn--on-dark">{tr.common.getInTouch}</a>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="container stats__grid">
      {tr.home.stats.map((s, i) => (
        <div class="stat">
          <span class="stat__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={statIcons[i]} />
          </span>
          <strong>{s.v}</strong><span>{s.l}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container intro">
      <div class="section-head reveal">
        <p class="eyebrow">{tr.home.introEyebrow}</p>
        <h2>{tr.home.introH2}</h2>
        <p class="lead mt-2">{tr.home.introLead}</p>
      </div>

      <div class="grid cols-2">
        {tr.home.capabilities.map((c) => (
          <div class="cap reveal">
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">{tr.home.servicesEyebrow}</p>
        <h2>{tr.home.servicesH2}</h2>
      </div>
      <div class="grid cols-2">
        {tr.services.items.map((s, i) => (
          <a href={localizePath('/services', lang)} class="svc-card card reveal">
            <span class="svc-card__no">{String(i + 1).padStart(2, '0')}</span>
            <h3>{s.title}</h3>
            <p>{s.summary}</p>
            <span class="svc-card__more">{tr.common.viewServices} <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hero { position: relative; color: #fff; isolation: isolate; }
  .hero__bg {
    position: absolute; inset: 0; z-index: -1; overflow: hidden;
    background:
      radial-gradient(80% 120% at 85% 0%, rgba(43,127,255,.40) 0%, rgba(43,127,255,0) 55%),
      radial-gradient(70% 110% at 0% 100%, rgba(0,179,214,.22) 0%, rgba(0,179,214,0) 55%),
      linear-gradient(110deg, #0e1217 0%, #161e29 55%, #11151b 100%);
  }
  .hero__bg::after {
    content: ""; position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(120% 90% at 70% 10%, #000 30%, transparent 75%);
  }

  .hero__inner { padding-block: clamp(5rem, 13vw, 9.5rem); max-width: 820px; }
  .hero h1 { color: #fff; margin-block: .4rem 1.5rem; }
  .hero .lead { color: #c7d2de; max-width: 60ch; }
  .hero__actions { display: flex; gap: .9rem; margin-top: 2.2rem; flex-wrap: wrap; }
  .hero .eyebrow { color: var(--blue-300); }
  .hero .eyebrow::before { background: var(--spark-300); }

  /* Hero text entrance (on load, staggered) */
  .hero .eyebrow { animation: heroIn .8s var(--ease) both; }
  .hero h1       { animation: heroIn .8s var(--ease) .12s both; }
  .hero .lead    { animation: heroIn .8s var(--ease) .24s both; }
  .hero__actions { animation: heroIn .8s var(--ease) .36s both; }
  @keyframes heroIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }

  @media (prefers-reduced-motion: reduce) {
    .hero .eyebrow, .hero h1, .hero .lead, .hero__actions { animation: none; }
  }

  .stats { border-bottom: 1px solid var(--line); }
  .stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat { padding: 2.2rem 1.5rem; text-align: center; border-right: 1px solid var(--line); }
  .stat:last-child { border-right: 0; }
  .stat__icon { display: grid; place-items: center; margin-bottom: 1.1rem; color: var(--blue-500); }
  .stat__icon svg { width: 50px; height: 50px; stroke-width: 1.25; }
  .stat strong { display: block; font-family: var(--font-heading); font-size: 1.75rem; font-weight: 700; color: var(--blue); letter-spacing: -.02em; }
  .stat span { font-size: .85rem; color: var(--muted); }
  @media (max-width: 720px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: 0; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--line); }
  }

  .cap { padding: 1.7rem 0; border-top: 2px solid var(--ink); }
  .cap h3 { margin-bottom: .6rem; }
  .cap p { color: var(--muted); font-size: .96rem; }

  .svc-card { padding: 1.9rem; display: flex; flex-direction: column; }
  .svc-card__no {
    font-family: var(--font-display); font-weight: 700; font-size: .9rem;
    color: var(--blue-500); letter-spacing: .06em; margin-bottom: .8rem;
  }
  .svc-card h3 { margin-bottom: .6rem; }
  .svc-card p { color: var(--muted); font-size: .96rem; }
  .svc-card__more {
    margin-top: 1.2rem; font-size: .85rem; font-weight: 600; color: var(--blue);
    display: inline-flex; align-items: center; gap: .4rem;
  }
  .svc-card:hover .svc-card__more .arrow { transform: translateX(3px); }
  .svc-card__more .arrow { transition: transform .2s var(--ease); }
</style>

<script>
  // Count-up for numeric stat values, when the strip scrolls into view.
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const nums = document.querySelectorAll<HTMLElement>('.stats .stat strong');
  if (!reduce && nums.length) {
    const animate = (el: HTMLElement) => {
      const target = el.textContent || '';
      if (!/\d/.test(target)) return;
      const parts = target.split(/(\d+)/);
      const dur = 1100;
      const start = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = parts.map((s) => (/^\d+$/.test(s) ? String(Math.round(Number(s) * e)) : s)).join('');
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = target;
      };
      requestAnimationFrame(step);
    };
    const io = new IntersectionObserver(
      (entries) => entries.forEach((en) => { if (en.isIntersecting) { animate(en.target as HTMLElement); io.unobserve(en.target); } }),
      { threshold: 0.5 }
    );
    nums.forEach((n) => io.observe(n));
  }
</script>
