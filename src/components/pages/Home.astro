---
import Base from '../../layouts/Base.astro';
import CtaBand from '../CtaBand.astro';
import { getLang, t, localizePath } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
---

<Base>
  <div class="slides">
    <!-- Slide 1 — hero -->
    <section class="slide slide--hero" data-slide="0">
      <div class="slide__bg" aria-hidden="true"><span class="blob blob--a"></span><span class="blob blob--b"></span></div>
      <div class="container slide__inner">
        <div class="slide__lead reveal">
          <p class="eyebrow">{tr.home.heroEyebrow}</p>
          <h1 set:html={tr.home.heroH1} />
          <p class="lead">{tr.home.heroLead}</p>
          <div class="slide__actions">
            <a href={localizePath('/services', lang)} class="btn btn--light">{tr.common.exploreServices} <span class="arrow">→</span></a>
            <a href={localizePath('/contact', lang)} class="btn btn--on-dark">{tr.common.getInTouch}</a>
          </div>
        </div>

        <div class="hero-stats reveal">
          {tr.home.stats.map((s) => (
            <div class="hero-stat">
              <strong>{s.v}</strong><span>{s.l}</span>
            </div>
          ))}
        </div>
      </div>
      <a class="slide__scroll" href="#adv-1" aria-label="Scroll">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6" /></svg>
      </a>
    </section>

    <!-- Slides 2..5 — advantages -->
    {tr.home.capabilities.map((c, i) => (
      <section class={`slide slide--adv adv-${i + 1}`} id={`adv-${i + 1}`} data-slide={i + 1}>
        <div class="slide__bg" aria-hidden="true"><span class="blob blob--a"></span><span class="blob blob--b"></span></div>
        <div class="container slide__inner slide__inner--adv">
          <div class="adv reveal">
            <span class="adv__no">{String(i + 1).padStart(2, '0')}</span>
            <p class="eyebrow">{tr.home.introEyebrow}</p>
            <h2>{c.title}</h2>
            <p class="lead">{c.text}</p>
            {i === 0 && (
              <a href={localizePath('/services', lang)} class="btn btn--light adv__cta">{tr.common.viewServices} <span class="arrow">→</span></a>
            )}
          </div>
        </div>
      </section>
    ))}
  </div>

  <CtaBand />
</Base>

<style>
  .slides { background: var(--ink); }

  .slide {
    position: relative; isolation: isolate; overflow: hidden;
    min-height: 100vh; min-height: 100svh;
    display: flex; align-items: center;
    color: #fff;
    padding-block: clamp(7rem, 14vh, 11rem);
  }

  /* ---- atmospheric, blurred backgrounds ---- */
  .slide__bg { position: absolute; inset: 0; z-index: -2; }
  .slide__bg::after {
    content: ""; position: absolute; inset: 0; z-index: 1;
    background-image:
      linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(130% 100% at 60% 30%, #000 25%, transparent 80%);
  }
  .blob {
    position: absolute; border-radius: 50%;
    filter: blur(90px); opacity: .55; will-change: transform;
  }
  .blob--a { width: 60vw; height: 60vw; max-width: 760px; max-height: 760px; }
  .blob--b { width: 46vw; height: 46vw; max-width: 560px; max-height: 560px; }

  /* base graphite wash on every slide */
  .slide::before {
    content: ""; position: absolute; inset: 0; z-index: -3;
    background: linear-gradient(160deg, #0d1116 0%, #141b25 55%, #0f141b 100%);
  }

  /* per-slide blob palettes & placement */
  .slide--hero .blob--a { top: -12%; right: -8%; background: #2b7fff; opacity: .5; }
  .slide--hero .blob--b { bottom: -18%; left: -10%; background: #00b3d6; opacity: .32; }
  .adv-1 .blob--a { top: -16%; left: -6%; background: #2b7fff; }
  .adv-1 .blob--b { bottom: -20%; right: -6%; background: #1763d6; opacity: .4; }
  .adv-2 .blob--a { top: -10%; right: -10%; background: #00b3d6; opacity: .42; }
  .adv-2 .blob--b { bottom: -22%; left: -8%; background: #2b7fff; opacity: .42; }
  .adv-3 .blob--a { top: -18%; left: 30%; background: #3a6df0; opacity: .45; }
  .adv-3 .blob--b { bottom: -16%; right: -12%; background: #0fb0cf; opacity: .35; }
  .adv-4 .blob--a { top: -14%; right: 8%; background: #2b7fff; opacity: .46; }
  .adv-4 .blob--b { bottom: -22%; left: -6%; background: #114ba6; opacity: .55; }

  /* ---- hero slide ---- */
  .slide__inner { width: 100%; }
  .slide__lead { max-width: 880px; }
  .slide--hero h1 { color: #fff; margin-block: .5rem 1.6rem; font-size: clamp(2.6rem, 6.5vw, 5rem); }
  .slide--hero .lead { color: #d3dde8; max-width: 62ch; }
  .slide--hero .eyebrow { color: var(--blue-300); }
  .slide--hero .eyebrow::before { background: var(--spark-300); }
  .slide__actions { display: flex; gap: .9rem; margin-top: 2.4rem; flex-wrap: wrap; }

  .hero-stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    margin-top: clamp(3rem, 7vh, 5rem);
    border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.12);
    border-radius: var(--radius-lg); overflow: hidden;
  }
  .hero-stat { background: rgba(13,17,22,.55); backdrop-filter: blur(4px); padding: 1.4rem 1.2rem; }
  .hero-stat strong {
    display: block; font-family: var(--font-heading); font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 700; color: #fff; letter-spacing: -.02em;
  }
  .hero-stat span { font-size: .82rem; color: #9fb0c2; }
  @media (max-width: 720px) { .hero-stats { grid-template-columns: repeat(2, 1fr); } }

  /* hero entrance */
  .slide--hero .slide__lead { animation: heroIn .9s var(--ease) both; }
  .slide--hero .hero-stats { animation: heroIn .9s var(--ease) .25s both; }
  @keyframes heroIn { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }

  /* ---- advantage slides ---- */
  .slide__inner--adv { display: flex; }
  .adv { max-width: 760px; }
  .slide--adv:nth-of-type(even) .slide__inner--adv { justify-content: flex-end; text-align: right; }
  .slide--adv:nth-of-type(even) .eyebrow { justify-content: flex-end; }
  .adv__no {
    display: block; font-family: var(--font-display); font-weight: 700;
    font-size: clamp(3rem, 9vw, 6.5rem); line-height: 1;
    color: transparent; -webkit-text-stroke: 1.5px rgba(255,255,255,.28);
    margin-bottom: 1rem;
  }
  .slide--adv h2 { color: #fff; font-size: clamp(2.1rem, 5.2vw, 3.8rem); margin-bottom: 1.2rem; }
  .slide--adv .lead { color: #c7d2de; font-size: clamp(1.1rem, 1.7vw, 1.4rem); max-width: 56ch; }
  .slide--adv:nth-of-type(even) .lead { margin-left: auto; }
  .slide--adv .eyebrow { color: var(--blue-300); }
  .slide--adv .eyebrow::before { background: var(--spark-300); }
  .adv__cta { margin-top: 2rem; }

  /* scroll cue */
  .slide__scroll {
    position: absolute; left: 50%; bottom: 2rem; transform: translateX(-50%);
    width: 42px; height: 42px; display: grid; place-items: center;
    border: 1px solid rgba(255,255,255,.25); border-radius: 50%; color: #fff;
    animation: bob 2.2s var(--ease) infinite;
  }
  .slide__scroll svg { width: 20px; height: 20px; }
  .slide__scroll:hover { background: rgba(255,255,255,.1); }
  @keyframes bob { 0%, 100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 6px); } }

  @media (prefers-reduced-motion: reduce) {
    .slide--hero .slide__lead, .slide--hero .hero-stats { animation: none; }
    .slide__scroll { animation: none; }
  }
</style>

<script>
  // Count-up for numeric stat values when the hero stats scroll into view.
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const nums = document.querySelectorAll<HTMLElement>('.hero-stat strong');
  if (!reduce && nums.length) {
    const animate = (el: HTMLElement) => {
      const target = el.textContent || '';
      if (!/\d/.test(target)) return;
      const parts = target.split(/(\d+)/);
      const dur = 1100;
      const start = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = parts.map((s) => (/^\d+$/.test(s) ? String(Math.round(Number(s) * e)) : s)).join('');
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = target;
      };
      requestAnimationFrame(step);
    };
    const io = new IntersectionObserver(
      (entries) => entries.forEach((en) => { if (en.isIntersecting) { animate(en.target as HTMLElement); io.unobserve(en.target); } }),
      { threshold: 0.5 }
    );
    nums.forEach((n) => io.observe(n));
  }
</script>
