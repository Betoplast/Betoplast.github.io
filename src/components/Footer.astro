---
import { site } from '../data/site';
import { getLang, t, localizePath, navItems } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr = t(lang);
const year = 2026;
---

<footer class="ftr">
  <div class="container ftr__grid">
    <div class="ftr__brand">
      <a href={localizePath('/', lang)} class="brand">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.3 2 5 13.4h4.9L8.7 22l8.3-12.1h-5z" /></svg>
        </span>
        <span class="brand__text">
          <span class="brand__top">BETOPLAST</span>
          <span class="brand__bottom">Energy &amp; Infrastructure</span>
        </span>
      </a>
      <p class="ftr__desc">{tr.footer.desc}</p>
    </div>

    <nav class="ftr__col" aria-label="Footer">
      <h4>{tr.footer.navigate}</h4>
      {navItems.map((item) => <a href={localizePath(item.href, lang)}>{tr.nav[item.key]}</a>)}
    </nav>

    <div class="ftr__col">
      <h4>{tr.footer.office}</h4>
      <address>
        {tr.address.line1}<br />
        {tr.address.line2}<br />
        {tr.address.country}
      </address>
      <p class="ftr__legal">{tr.legalEntity}<br />{tr.footer.uid} {site.uid}</p>
    </div>
  </div>

  <div class="container ftr__bottom">
    <span>© {year} {tr.legalEntity}. {tr.footer.rights}</span>
    <span class="ftr__note">{tr.footer.note}</span>
  </div>
</footer>

<style>
  .ftr { background: var(--ink); color: #9aa6b3; padding-top: clamp(3rem, 6vw, 4.5rem); }
  .ftr__grid {
    display: grid; grid-template-columns: 1.6fr 1fr 1.2fr; gap: 2.5rem;
    padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,.1);
  }
  .ftr .brand { display: flex; align-items: center; gap: .7rem; }
  .ftr .brand__mark {
    width: 44px; height: 44px; border-radius: 8px; flex: none;
    display: grid; place-items: center;
    background: rgba(255,255,255,.06); color: var(--blue-500);
  }
  .ftr .brand__mark svg { width: 22px; height: 22px; }
  .ftr .brand__text { display: flex; flex-direction: column; line-height: 1; }
  .ftr .brand__top {
    font-family: var(--font-display); font-weight: 700; font-size: 1.12rem;
    letter-spacing: .02em; color: #fff;
  }
  .ftr .brand__bottom {
    font-family: var(--font-display); font-weight: 600; text-transform: uppercase;
    font-size: .6rem; letter-spacing: .12em; color: var(--blue-300);
    margin-top: .3rem;
  }
  .ftr__desc { margin-top: 1.1rem; max-width: 38ch; font-size: .92rem; line-height: 1.6; color: #818d9b; }
  .ftr__col h4 { color: #fff; font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 1.1rem; }
  .ftr__col a { display: block; padding: .3rem 0; font-size: .92rem; color: #9aa6b3; transition: color .18s var(--ease); }
  .ftr__col a:hover { color: #fff; }
  .ftr__col address { font-style: normal; font-size: .92rem; line-height: 1.7; color: #9aa6b3; }
  .ftr__legal { margin-top: 1rem; font-size: .82rem; color: #6b7785; }
  .ftr__bottom {
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    padding-block: 1.6rem; font-size: .82rem; color: #6b7785;
  }
  @media (max-width: 820px) { .ftr__grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
